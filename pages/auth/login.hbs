<div style="background-color:#f6f1e4 ;" class="container ">
    <div class="row top ">
        <div class="col s12 ">
            <ul class="tabs " style="background-color:#f6f1e4 ;">
                <li class="tab  col s4 offset-s2 "><a class="active " href="#login"> Вхід </a></li>
                <li class="tab col  s4"><a href="#registr">Реєстрація</a></li>
            </ul>
        </div>
        <div id="login" class="col s6 offset-s3">
            <h2>Увійти до магазину</h2>
            <form>
                <div class="input-field">
                    <input id="email" name="email" type="email" class="validate" required>
                    <label for="email">Email</label>
                    <span class="helper-text" data-error="Введіть email"></span>
                </div>

                <div class="input-field">
                    <input id="password" name="password" type="password" class="validate" required>
                    <label for="password">Пароль</label>
                    <span class="helper-text" data-error="Введіть пароль"></span>
                </div>
                <button class="btn " onclick="selectUser()" >Увійти</button>
            </form>
        </div>
        <div id="registr" class="col s6 offset-s2">
            <h2>Створити акаунт</h2>
            <form  >
                <div class="input-field">
                    <input  id="rename" name="login" type="text" class="validate" required>
                    <label for="rename">Введіть логін</label>
                    <span class="helper-text" data-error="Введіть логін"></span>
                </div>
                <div class="input-field">
                    <input id="remail" name="email" type="email" class="validate" required>
                    <label for="remail">Email</label>
                    <span class="helper-text" data-error="Введіть email"></span>
                </div>

                <div class="input-field">
                    <input id="rpassword" name="password" type="password" class="validate" required>
                    <label for="rpassword">Пароль</label>
                    <span class="helper-text" data-error="Введіть пароль"></span>
                </div>
                <button class="btn"  onclick="insertUser()"  >Зареєструватись </button>
            </form>
        </div>

    </div>
</div>